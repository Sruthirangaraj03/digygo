# DigyGo CRM — Environment Variables
# Copy to backend/.env and fill in values before running

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://digygo_user:password@localhost:5432/digygocrm

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-here-minimum-64-characters-long-change-in-production
JWT_EXPIRES_IN=15m

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Encryption (AES-256, 32-char key) ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=

# ── Meta / Facebook Lead Ads ──────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=digygo_webhook_verify
# Public URL of this backend (used to build OAuth redirect_uri and webhook URL)
WEBHOOK_BASE_URL=https://your-domain.com

# ── WhatsApp Business API ─────────────────────────────────────────────────────
# (credentials stored per-tenant in DB after setup via /api/integrations/waba/setup)

# ── SMTP (for staff invites, password reset, and workflow email automation) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=DigyGo CRM
SMTP_FROM_EMAIL=noreply@digygocrm.com
