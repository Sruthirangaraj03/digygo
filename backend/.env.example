NODE_ENV=production
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://digygo_user:digygo123@localhost:5432/digygocrm

# Auth
JWT_SECRET=replace_with_strong_random_string_min_32_chars
JWT_EXPIRES_IN=15m
ENCRYPTION_KEY=replace_with_exactly_32_char_string

# Domain — set to your Hostinger domain
FRONTEND_URL=https://yourdomain.com
WEBHOOK_BASE_URL=https://yourdomain.com

# Meta / Facebook
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=
META_WEBHOOK_VERIFY_TOKEN=d7dde81a60c0867e0866cdb073538ce8
META_API_VERSION=v21.0

# SMTP (optional — for email automation actions)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=DigyGo CRM
SMTP_FROM_EMAIL=
